# =====================================================================
# AIリード対応ワークフロー / AI Lead Ops Workflow Hub — 環境変数サンプル
# すべて未設定でも「デモモード」で全機能が動作します。
# 本番運用時のみ必要な値を設定してください。
# =====================================================================

# --- Supabase（未設定時はインメモリのデモデータで動作） ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI プロバイダ ---
# AI_PROVIDER: "claude" | "openai" | "mock"（未設定 or "mock" でモックAI）
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# 任意: 使用モデルの上書き（既定は最新の Claude Opus 4.8）
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini

# --- n8n Webhook（未設定時は送信スキップ＝デモモード表示） ---
N8N_WEBHOOK_URL=

# --- Dify 連携（未設定時はモック回答） ---
DIFY_API_KEY=
DIFY_APP_ID=
DIFY_API_URL=https://api.dify.ai/v1
